{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "site": "reaksiyontalep",
    "public": ".",
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "archive-unused-js/**",
      "outputs/**",
      "product_trees_upload.json",
      "product_tree.js",
      "paraf_aliases_upload.json",
      "users_for_admin_lookup.json",
      "orders_sample.json",
      "product_tree_*.json",
      "firebase-debug.log"
    ]
  }
}
